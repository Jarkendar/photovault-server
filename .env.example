# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit secrets.

SERVER_PORT=8080

POSTGRES_USER=photovault
POSTGRES_PASSWORD=change-me
POSTGRES_DB=photovault

# JWT — generate a strong random secret for production (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-before-deploying
# JWT_ISSUER=photovault
# JWT_AUDIENCE=photovault-client
# JWT_ACCESS_TTL_MIN=60
# JWT_REFRESH_TTL_DAYS=30

# Storage — path to the directory containing photo binary assets.
# In Docker this is set to /data/photos (mounted as a named volume).
# For local dev, point it at any writable directory.
PHOTO_STORAGE_ROOT=./data/photos

# Categorizer — shell command the server runs via `bash -c` to trigger categorization.
# The command must be able to reach the database and photo storage on its own.
# Leave empty to disable the Run Categorizer button in the face-labeler UI (returns 409).
#
# Local dev (Python venv inside the categorizer submodule):
# CATEGORIZER_CMD=.venv/bin/python -m photovault_categorizer.cli.categorize
# CATEGORIZER_WORKDIR=./categorizer
#
# Production Pi (server running in Docker — docker.sock and categorizer/.env are mounted via compose):
# CATEGORIZER_CMD=/usr/bin/docker run --rm --env-file /categorizer/.env -v /data/photos:/photos:ro -v /data/vectors:/vectors photovault-categorizer
# CATEGORIZER_WORKDIR=/app
# CATEGORIZER_ENVFILE=/absolute/host/path/to/categorizer/.env
CATEGORIZER_CMD=
CATEGORIZER_WORKDIR=./categorizer
CATEGORIZER_ENVFILE=
